# Pak RW - DisCloud / Local Development
# Jangan isi value asli lalu upload ke GitHub. Isi ENV langsung di DisCloud panel.

DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
MONGODB_URI=
OPENROUTER_API_KEY=
AI_KEY=
NODE_ENV=production

# DisCloud default: dashboard dimatikan dulu supaya bot Discord stabil.
DASHBOARD_ENABLED=false

# Opsional jika dashboard ingin diaktifkan lagi nanti:
DASHBOARD_PASSWORD=
PORT=3000
OT_PORT=3000

# Opsional hemat OpenRouter
AI_DAILY_LIMIT=180
AI_GLOBAL_COOLDOWN_MS=1500
AI_MAX_TOKENS=560
AI_CACHE_TTL_MS=180000

# Router model AI Pak RW v10.10.90
OPENROUTER_SMART_MODEL=openai/gpt-5.4
OPENROUTER_ECONOMY_MODEL=openai/gpt-5.4-mini
