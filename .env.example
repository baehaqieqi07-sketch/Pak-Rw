# Pak RW - DisCloud / Local Development
# Jangan isi value asli lalu upload ke GitHub. Isi ENV langsung di DisCloud panel.

DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
MONGODB_URI=
OPENROUTER_API_KEY=
AI_KEY=
NODE_ENV=production

# DisCloud default: dashboard dimatikan dulu supaya bot Discord stabil.
DASHBOARD_ENABLED=false

# Wajib diisi dengan password kuat jika dashboard diaktifkan di production:
DASHBOARD_PASSWORD=
PORT=3000
OT_PORT=3000

# Opsional hemat OpenRouter
AI_DAILY_LIMIT=180
AI_GLOBAL_COOLDOWN_MS=1500
AI_MAX_TOKENS=560
AI_CACHE_TTL_MS=180000

# Router model AI Pak RW v10.10.90
OPENROUTER_SMART_MODEL=openai/gpt-4o-mini
OPENROUTER_ECONOMY_MODEL=openai/gpt-4o-mini

# AI Limit Auto Recovery v10.10.97
AI_AUTO_RECOVERY=true
AI_LIMIT_MODE=temporary
AI_TRY_NORMAL_AFTER_COOLDOWN=true
AI_LOCAL_FALLBACK_UNTIL_RESET=true
AI_SHOW_RESET_TIME=true
AI_RATE_LIMIT_COOLDOWN_SECONDS=300
AI_PROVIDER_ERROR_COOLDOWN_SECONDS=120
AI_CREDIT_RECHECK_SECONDS=1800
AI_AUTH_RECHECK_SECONDS=3600
AI_USE_RETRY_AFTER_HEADER=true
AI_RETRY_ON_TOKEN_LIMIT=true
AI_TOKEN_LIMIT_RETRY_MAX=1
AI_PROVIDER_RETRY_MAX=1
AI_NO_RETRY_ON_AUTH=true
AI_NO_RETRY_ON_CREDIT=true
AI_TOKEN_BUDGET=3000
AI_MAX_PROMPT_CHARS=8500
AI_MAX_SYSTEM_CHARS=1800
AI_MAX_MEMORY_CHARS=900
AI_MAX_HISTORY_TURNS=2
AI_MAX_USER_MESSAGE_CHARS=1500
AI_MAX_REPLY_TOKENS=500
AI_SAFE_REPLY_TOKENS=350
AI_FALLBACK_TEMPORARY=true
AI_LOCAL_FALLBACK_ONLY_THIS_MESSAGE=true
AI_STORE_LIMIT_FALLBACK_MEMORY=false
AI_MEMORY_SUMMARY_ONLY=true
AI_COOLDOWN_USER=10
AI_COOLDOWN_CHANNEL=3
AI_DAILY_LIMIT_PER_USER=30
AI_DAILY_LIMIT_OWNER=999
AI_SPAM_WINDOW_SECONDS=30
AI_SPAM_MAX_MESSAGES=5
AI_CURHAT_SYSTEM_CHARS=1000
AI_CURHAT_MEMORY_CHARS=700
AI_CURHAT_HISTORY_TURNS=2
AI_CURHAT_MAX_REPLY_TOKENS=450
AI_FALLBACK_MAX_CHARS_MEMBER=350
AI_FALLBACK_MAX_CHARS_OWNER=700
